{
    "redirects": [
      {
        "source": "$host",
        "destination": "$wwwhost",
        "statusCode": 301
      }
    ],
    "headers": [
    {
      "source": "/posts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
